{
  "name": "mi-dieta-api",
  "version": "1.0.0",
  "description": "REST API for Mi Dieta using Express + Supabase",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "check-syntax": "node scripts/check-syntax.js",
    "reference:portion-equivalents": "node scripts/enrich-ingredient-reference-portions.js",
    "reference:portion-report": "node scripts/report-ingredient-portion-coverage.js",
    "reference:portion-report:strict": "node scripts/report-ingredient-portion-coverage.js --strict",
    "reference:portion-overrides:sync": "node scripts/sync-ingredient-portion-overrides.js",
    "reference:export-frontend-bundle": "node scripts/export-frontend-ingredient-reference-bundle.js",
    "reference:curation-hints": "node scripts/report-portion-curation-review.js",
    "seed:meals": "node scripts/seed-meals.mjs",
    "seed:meals:dry": "node scripts/seed-meals.mjs --dry-run",
    "verify:meals": "node scripts/verify-meals.mjs"
  },
  "keywords": [
    "express",
    "supabase",
    "rest-api"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@sentry/node": "^10.49.0",
    "@supabase/supabase-js": "^2.102.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
